{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "driver: build",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver --parallel $(nproc)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "driver: clean rebuild",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver --clean-first --parallel $(nproc)",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "driver: testsuite",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver-testsuite",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "driver: autotest",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver-autotest",
      "group": "test",
      "problemMatcher": [],
      "dependsOn": ["driver: build"]
    }
  ]
}
