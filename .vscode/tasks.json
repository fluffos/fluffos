{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: build driver",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver --parallel $(nproc)",
      "osx": {
        "command": "cmake --build \"${workspaceFolder}/build\" --target driver --parallel $(sysctl -n hw.logicalcpu)"
      },
      "windows": {
        "command": "cmake --build \"${workspaceFolder}/build\" --target driver --parallel %NUMBER_OF_PROCESSORS%"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "driver - testsuite",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver-testsuite",
      "windows": {
        "command": "cmake --build \"${workspaceFolder}/build\" --target driver-testsuite"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "driver - autotest",
      "type": "shell",
      "command": "cmake --build \"${workspaceFolder}/build\" --target driver-autotest",
      "windows": {
        "command": "cmake --build \"${workspaceFolder}/build\" --target driver-autotest"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
