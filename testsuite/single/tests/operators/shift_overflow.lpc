// LPC ints are 64-bit (int64_t); '<<'/'>>' with a shift count that is
// negative or >= 64 is C++ undefined behavior. Three separate sites
// computed this with no guard: the runtime shift efuns (f_lsh/f_rsh/
// f_lsh_eq/f_rsh_eq, src/packages/ops/ops.cc), the compiler's constant
// folder (src/compiler/internal/trees.cc), and the #if preprocessor
// expression evaluator (src/compiler/internal/lexer_rules_pp.cc,
// already guarded for '/' and '%' but not 's'/'S').
void do_tests() {
    int x, n;
    mixed err;

    // Runtime '<<' / '>>' with an out-of-range shift count must be a
    // clean, catchable error, not a crash. Non-constant operands (a
    // local variable) so the compiler's constant folder can't collapse
    // these at compile time -- that's tested separately below.
    n = 100;
    err = catch(x = 1 << n);
    ASSERT(err);
    n = -1;
    err = catch(x = 1 >> n);
    ASSERT(err);

    // Runtime '<<=' / '>>=' likewise.
    x = 1;
    n = 100;
    err = catch(x <<= n);
    ASSERT(err);
    x = 1;
    n = -1;
    err = catch(x >>= n);
    ASSERT(err);

    // Ordinary in-range shifts must still work exactly as before,
    // both as compile-time constants and at runtime.
    ASSERT_EQ(8, 1 << 3);
    ASSERT_EQ(1, 8 >> 3);
    n = 3;
    ASSERT_EQ(8, 1 << n);
    ASSERT_EQ(1, 8 >> n);
    x = 1;
    x <<= 3;
    ASSERT_EQ(8, x);
    x = 8;
    x >>= 3;
    ASSERT_EQ(1, x);

    // Compile-time constant folding (trees.cc) with an out-of-range
    // shift count must not crash the driver at compile time -- it's
    // now a clean (catchable) compile error, not a crash.
    string src = "int f() { return 1 << 100; }\n";
    rm("/gen_shift_const.c");
    write_file("/gen_shift_const.c", src);
    catch(load_object("/gen_shift_const"));
    ASSERT(1);
    rm("/gen_shift_const.c");

    // The #if preprocessor evaluator's shift operators must not crash
    // the driver at compile time either.
    src = "#if (1 << 100)\n"
          "int marker = 1;\n"
          "#endif\n"
          "int done = 1;\n";
    rm("/gen_shift_if.c");
    write_file("/gen_shift_if.c", src);
    catch(load_object("/gen_shift_if"));
    ASSERT(1);
    rm("/gen_shift_if.c");
}
