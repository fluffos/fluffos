void iter_buffer_two_vars() {
  buffer b = allocate_buffer(2);
  foreach (string k, int v in b) {}
}

void do_tests() {
  int *x = ({ 1, 2, 3, 4 });
  int *x_orig = ({ 1, 2, 3, 4 });
  int count = 0;
  string str = "abcdefg";

  foreach (int i in x) {
    count++;
  }

  ASSERT_EQ(sizeof(x), count);
  ASSERT_EQ(x_orig, x);

  count = 0;
  foreach (int ref i in x) {
    i++;
    count++;
  }

  ASSERT_EQ(sizeof(x), count);
  ASSERT_EQ(({ 2, 3, 4, 5 }), x);

  {
    mapping tmp = ([ "x": 1,
      "y": 2,
      "z": 3 ]);

    count = 0;
    foreach (string key, string val in tmp) {
      write(key + ":" + val + "\n");
      count++;
    }

    ASSERT_EQ(sizeof(tmp), count);
  }

  {
    string tmp = "";

    foreach (int c in str) {
      tmp += sprintf("%c", c);
    }

    ASSERT_EQ(tmp, str);
  }

  {
    foreach (int ref c in str) {
      c++;
    }

    ASSERT_EQ("abcdefg", str);  // not suppose to change
  }

  // A ref loop variable over a string must read the actual characters.
  // The shared codepoint cursor used to be advanced before the body ran,
  // so every read through the ref was off by one.
  {
    int r = 0;
    foreach (int ref c in "abc") {
      r = r * 1000 + c;
    }
    ASSERT_EQ(97098099, r);
  }

  // Nested foreach over strings: the EGC cursor is per-loop stack state.
  // The inner loop used to reset the shared iterator out from under the
  // outer loop and crash the driver.
  {
    string r = "";
    foreach (int a in "ab") {
      foreach (int b in "xy") {
        r += sprintf("%c%c ", a, b);
      }
    }
    ASSERT_EQ("ax ay bx by ", r);
  }

  // Same, with the outer loop variable a ref: reads stay on the outer
  // loop's own character across the inner loop.
  {
    string r = "";
    foreach (int ref a in "ab") {
      foreach (int b in "xy") {
        r += sprintf("%c%c ", a, b);
      }
    }
    ASSERT_EQ("ax ay bx by ", r);
  }

  // Nested string foreach with multi-byte UTF-8 EGCs.
  {
    int n = 0;
    foreach (int a in "héé") {
      foreach (int b in "🍆🍠") {
        n++;
      }
    }
    ASSERT_EQ(6, n);
  }

  // foreach over a buffer iterates its bytes as unsigned ints (0..255)
  {
    buffer b = allocate_buffer(4);
    int *seen = ({});

    b[0] = 0; b[1] = 1; b[2] = 200; b[3] = 255;
    foreach (int v in b) {
      seen += ({ v });
    }
    ASSERT_EQ(({ 0, 1, 200, 255 }), seen);
  }

  // empty buffer: zero iterations
  {
    int n = 0;
    foreach (int v in allocate_buffer(0)) {
      n++;
    }
    ASSERT_EQ(0, n);
  }

  // nested buffer foreach: cursors are per-loop
  {
    buffer b1 = allocate_buffer(2), b2 = allocate_buffer(2);
    int n = 0;

    b1[0] = 1; b1[1] = 2; b2[0] = 3; b2[1] = 4;
    foreach (int bx in b1) {
      foreach (int by in b2) {
        n += bx * by;
      }
    }
    ASSERT_EQ(21, n);
  }

  // two-variable foreach over a buffer is still an error (mapping expected)
  {
    string err = catch(iter_buffer_two_vars());
    ASSERT_EQ(0, strsrch(err, "*Bad argument 2 to foreach"));
  }

  // Issue #1127: the iteration count used to be stored in a 16-bit field,
  // so containers with more than 65535 entries iterated size % 65536 times
  // (65536 entries iterated zero times).
  {
    int i, bigcount;
    mixed *big;
    mapping bigmap = ([]);

    big = allocate(65536, 1);
    bigcount = 0;
    foreach (int v in big) {
      bigcount += v;
    }
    ASSERT_EQ(65536, bigcount);

    big = allocate(70000, 1);
    bigcount = 0;
    foreach (int v in big) {
      bigcount += v;
    }
    ASSERT_EQ(70000, bigcount);

    for (i = 0; i < 70000; i++) {
      bigmap[i] = 1;
    }
    ASSERT_EQ(70000, sizeof(bigmap));
    bigcount = 0;
    foreach (int k, int v in bigmap) {
      bigcount += v;
    }
    ASSERT_EQ(70000, bigcount);
  }
}
