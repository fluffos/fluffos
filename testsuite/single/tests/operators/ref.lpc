// Thorough tests for pass-by-reference: the ref keyword and its & sugar in
// parameter declarations, call arguments, and foreach loops -- plus the
// string-char cases, which share one arming/assignment path with s[i]
// lvalues (aim_lvalue_codepoint / assign_lvalue_codepoint in interpret.cc).

class Pt {
  int x;
  int y;
}

void increment(int ref value) {
  value++;
}

// ref parameters of every value type: reassignment propagates to the caller
void add_half(float ref v) { v += 0.5; }
void extend(string ref s) { s += "!"; }
void reassign_map(mapping ref m) { m = ([ "new": 1 ]); }
void reassign_obj(object ref o) { o = 0; }
void reassign_fun(function ref f) { f = (: 42 :); }
void reassign_buf(buffer ref b) { b = allocate_buffer(1); }
void reassign_cls(class Pt ref p) { p = new(class Pt, x: 7, y: 8); }
void reassign_mixed(mixed ref v) { v = "changed"; }

void reassign_map_by_value(mapping m) { m = ([ "new": 1 ]); }

void append_item(mixed ref *arr, mixed item) {
  arr += ({ item });
}

// & sugar in parameter declarations
void decrement(int & value) {
  value--;
}

void prepend_item(mixed & *arr, mixed item) {
  arr = ({ item }) + arr;
}

// forwarding a ref parameter onward keeps aliasing the original variable
void chain_ref(int ref value) {
  increment(ref value);
}

void chain_amp(int ref value) {
  increment(& value);
}

void set_char(int ref c) {
  c = 'Z';
}

void by_value(int value) {
  value = 999;
}

string flag_str;
int *flag_seen;

void iter_flag_collect() {
  flag_seen = ({});
  foreach (int ref c in flag_str) {
    flag_seen += ({ c });
  }
}

void iter_flag_empty_body() {
  foreach (int ref c in flag_str) {}
}

string gen_load_error(string name, string src) {
  string err;

  rm("/" + name + ".c");
  write_file("/" + name + ".c", src);
  err = catch(load_object("/" + name));
  rm("/" + name + ".c");
  return err;
}

void do_tests() {
  string mc_lvalue = "*Indexed character is multi-codepoint.\n";

  // Test ref keyword in call arguments
  {
    int x = 10;
    increment(ref x);
    ASSERT_EQ(11, x);
  }

  // Test & as syntactic sugar for ref in call arguments
  {
    int x = 10;
    increment(& x);
    ASSERT_EQ(11, x);
  }

  // Without ref, arguments are by value
  {
    int x = 10;
    by_value(x);
    ASSERT_EQ(10, x);
  }

  // Test & with array ref parameter
  {
    mixed *arr = ({ 1, 2, 3 });
    append_item(& arr, 4);
    ASSERT_EQ(({ 1, 2, 3, 4 }), arr);
  }

  // Test & in parameter declarations
  {
    int x = 10;
    decrement(& x);
    ASSERT_EQ(9, x);
    decrement(ref x);
    ASSERT_EQ(8, x);

    mixed *arr = ({ 2, 3 });
    prepend_item(& arr, 1);
    ASSERT_EQ(({ 1, 2, 3 }), arr);
  }

  // A ref parameter can be forwarded by ref through another call
  {
    int x = 5;
    chain_ref(ref x);
    chain_amp(& x);
    ASSERT_EQ(7, x);
  }

  // ref parameters work for every value type: reassigning the parameter
  // reassigns the caller's variable
  {
    float f = 1.0;
    string s = "hi";
    mapping m = ([ "old": 1 ]);
    object o = this_object();
    function fn = (: 1 :);
    buffer b = allocate_buffer(3);
    class Pt p = new(class Pt, x: 1, y: 2);
    mixed any = 5;

    add_half(ref f);
    add_half(& f);
    ASSERT_EQ(2.0, f);
    extend(ref s);
    ASSERT_EQ("hi!", s);
    reassign_map(ref m);
    ASSERT_EQ(({ "new" }), keys(m));
    reassign_obj(ref o);
    ASSERT_EQ(0, o);
    reassign_fun(ref fn);
    ASSERT_EQ(42, evaluate(fn));
    reassign_buf(ref b);
    ASSERT_EQ(1, sizeof(b));
    reassign_cls(ref p);
    ASSERT_EQ(7, p.x);
    ASSERT_EQ(8, p.y);
    reassign_mixed(ref any);
    ASSERT_EQ("changed", any);
  }

  // Contrast: mappings (like arrays) are reference types, so member writes
  // propagate even by value -- but REASSIGNING the parameter only
  // propagates with ref
  {
    mapping m = ([ "old": 1 ]);

    reassign_map_by_value(m);
    ASSERT_EQ(({ "old" }), keys(m));
    reassign_map(ref m);
    ASSERT_EQ(({ "new" }), keys(m));
  }

  // Call-site ref to an array element / a mapping value / a buffer byte
  // writes back
  {
    int *arr = ({ 1, 2, 3 });
    mapping m = ([ "k": 41 ]);
    buffer b = allocate_buffer(3);

    increment(ref arr[1]);
    ASSERT_EQ(({ 1, 3, 3 }), arr);
    increment(& m["k"]);
    ASSERT_EQ(42, m["k"]);
    b[1] = 10;
    increment(ref b[1]);
    ASSERT_EQ(11, b[1]);
    increment(& b[<1]);
    ASSERT_EQ(1, b[2]);
  }

  // Call-site ref to a class member writes back (both . and -> spellings)
  {
    class Pt p = new(class Pt, x: 1, y: 2);

    increment(ref p.x);
    ASSERT_EQ(2, p.x);
    increment(& p->y);
    ASSERT_EQ(3, p->y);
  }

  // Call-site ref to a string char writes back into the string,
  // through forward and reverse indexes
  {
    string s = "abc";

    increment(ref s[1]);
    ASSERT_EQ("acc", s);
    set_char(& s[<1]);
    ASSERT_EQ("acZ", s);
  }

  // Test & in foreach over an array (mutates in place)
  {
    int *nums = ({ 1, 2, 3 });
    foreach (int & n in nums) {
      n *= 2;
    }
    ASSERT_EQ(({ 2, 4, 6 }), nums);
  }

  // Test ref keyword in foreach
  {
    int *nums = ({ 1, 2, 3 });
    foreach (int ref n in nums) {
      n += 10;
    }
    ASSERT_EQ(({ 11, 12, 13 }), nums);
  }

  // foreach ref over mapping values mutates in place; values of any type
  // can be replaced through the ref
  {
    mapping m = ([ "a": 1, "b": 2 ]);
    mapping mm = ([ "s": "x", "arr": ({ 1 }) ]);

    foreach (string k, int ref v in m) {
      v *= 10;
    }
    ASSERT_EQ(10, m["a"]);
    ASSERT_EQ(20, m["b"]);

    foreach (string k, mixed ref v in mm) {
      v = k;
    }
    ASSERT_EQ("s", mm["s"]);
    ASSERT_EQ("arr", mm["arr"]);
  }

  // foreach ref over a buffer mutates the bytes in place (buffers are
  // reference types, like arrays)
  {
    buffer b = allocate_buffer(3);

    b[0] = 1; b[1] = 2; b[2] = 3;
    foreach (int ref v in b) {
      v = v * 2;   // read + assign through the ref
    }
    ASSERT_EQ(2, b[0]);
    ASSERT_EQ(4, b[1]);
    ASSERT_EQ(6, b[2]);

    foreach (int ref v in b) {
      v++;
    }
    ASSERT_EQ(3, b[0]);

    foreach (int ref v in b) {
      v += 2;
    }
    ASSERT_EQ(5, b[0]);
  }

  // buffer bytes stay bytes: reads are unsigned (0..255), and writing a
  // value outside 0..255 through the ref errors like b[i] = v does
  {
    string range_err = "*Buffer byte value out of range: must be 0..255.\n";
    buffer b = allocate_buffer(2);
    int got;

    b[0] = 200; b[1] = 255;
    foreach (int ref v in b) {
      got = v;
    }
    ASSERT_EQ(255, got);   // read the actual unsigned value

    foreach (int ref v in b) {
      ASSERT_EQ(range_err, catch(v = 256));
      break;
    }
    foreach (int ref v in b) {
      ASSERT_EQ(range_err, catch(v = -1));
      break;
    }
    ASSERT_EQ(200, b[0]);  // failed writes leave the byte unchanged
  }

  // Each ref loop carries its own byte lvalue: nested buffer ref loops --
  // and b[i] lvalues used in the body -- never alias each other. (The
  // outer write used to land in the INNER loop's buffer via the shared
  // byte lvalue.)
  {
    buffer b1 = allocate_buffer(2), b2 = allocate_buffer(2);
    buffer o = allocate_buffer(1);

    foreach (int ref x in b1) {
      foreach (int ref y in b2) {
        y++;
      }
      o[0]++;      // arms the shared b[i] lvalue mid-loop
      x = 9;
    }
    ASSERT_EQ(9, b1[0]);
    ASSERT_EQ(9, b1[1]);
    ASSERT_EQ(2, b2[0]);
    ASSERT_EQ(2, b2[1]);
    ASSERT_EQ(2, o[0]);
  }

  // Same shape over arrays (also pins the ref_t leak fix for a ref loop
  // variable reused by a re-entered inner loop)
  {
    int *a1 = ({ 0, 0 }), *a2 = ({ 0, 0 });

    foreach (int ref x in a1) {
      foreach (int ref y in a2) {
        y++;
      }
      x = 9;
    }
    ASSERT_EQ(({ 9, 9 }), a1);
    ASSERT_EQ(({ 2, 2 }), a2);
  }

  // ===== foreach ref over strings =====

  // Reads deliver the actual characters (used to be off by one)
  {
    int r = 0;
    foreach (int ref c in "abc") {
      r = r * 1000 + c;
    }
    ASSERT_EQ(97098099, r);
  }

  // Multi-byte, single-codepoint EGCs read fine through a ref
  {
    int *seen = ({});
    foreach (int ref c in "héé🍆") {
      seen += ({ c });
    }
    ASSERT_EQ(({ 'h', 233, 233, 127814 }), seen);
  }

  // Writes through the ref use the s[i] assignment logic but apply to the
  // loop's by-value copy: the iterated variable never changes
  {
    string s = "abc";
    foreach (int ref c in s) {
      c = 'z';
    }
    ASSERT_EQ("abc", s);
    foreach (int ref c in s) {
      c++;
    }
    ASSERT_EQ("abc", s);
    foreach (int ref c in s) {
      c += 5;
    }
    ASSERT_EQ("abc", s);
  }

  // Invalid assignments through the ref error the same way as s[i] = c.
  // (One loop per case: a caught error unwinds the loop variable's ref,
  // so the next use through the same ref reports "Reference is invalid".)
  {
    string zero_byte = "*Strings cannot contain 0 byte.\n";
    string bad_cp = "*Strings cannot contain invalid utf8 codepoint.\n";

    foreach (int ref c in "abc") {
      ASSERT_EQ(zero_byte, catch(c = 0));
      break;
    }
    foreach (int ref c in "abc") {
      ASSERT_EQ(bad_cp, catch(c = 0x110000));
      break;
    }
  }

  // An EGC of up to 4 bytes indexes as its first codepoint -- same rule as
  // s[i]: 'e' + combining accent (U+0301) reads as 'e', and writing through
  // the ref succeeds (it replaces the base codepoint in the loop's copy)
  {
    string s = sprintf("a%c%cb", 'e', 769);
    int *seen = ({});

    ASSERT_EQ(3, strlen(s));
    ASSERT_EQ('e', s[1]);
    foreach (int ref c in s) {
      seen += ({ c });
      c += 1;
    }
    ASSERT_EQ(({ 'a', 'e', 'b' }), seen);
    ASSERT_EQ(sprintf("a%c%cb", 'e', 769), s);
  }

  // A wider EGC (a flag emoji is two 4-byte codepoints) cannot be a char
  // lvalue: a ref loop cleanly errors when it reaches it -- exactly like
  // s[i] -- whether or not the body touches the loop variable.
  // (It used to silently read as -1.)
  {
    string s = "a🇺🇸b";
    int *seen;

    ASSERT_EQ(mc_lvalue, catch(s[1] = 'Z'));      // the s[i] behavior it mirrors

    flag_str = s;
    ASSERT_EQ(mc_lvalue, catch(iter_flag_collect()));
    ASSERT_EQ(({ 'a' }), flag_seen);              // errored at the flag, not before
    ASSERT_EQ(mc_lvalue, catch(iter_flag_empty_body()));

    // the non-ref form still iterates (delivering -1 for the wide EGC)
    seen = ({});
    foreach (int c in s) {
      seen += ({ c });
    }
    ASSERT_EQ(({ 'a', -1, 'b' }), seen);
  }

  // ===== compile-time rejections (generated source) =====

  // ref/& outside a function argument list is a compile error
  ASSERT(gen_load_error("gen_ref_expr", "void f() { int x = 1; int y = & x; }\n"));
  ASSERT(gen_load_error("gen_ref_expr2", "void f() { int x = 1; int y = ref x; }\n"));

  // a reference to a range is a compile error
  ASSERT(gen_load_error("gen_ref_range",
    "void g(mixed ref v) {}\n"
    "void f() { string s = \"abc\"; g(ref s[0..1]); }\n"));

  // a mapping KEY may not be a ref in foreach (keys are hashed; mutating
  // one in place would corrupt the mapping) -- compile error
  ASSERT(gen_load_error(
    "gen_ref_mapkey",
    "void f() { mapping m = ([ \"a\": 1 ]); foreach(string ref k, int v in m) {} }\n"));

  // Bitwise & and &= still parse and evaluate as binary AND
  {
    int a = 6, b = 3;
    ASSERT_EQ(2, a & b);
    ASSERT_EQ(2, 6 & 3);
    a &= b;
    ASSERT_EQ(2, a);
    ASSERT_EQ(6, 4 | 6 & 3);
  }
}
