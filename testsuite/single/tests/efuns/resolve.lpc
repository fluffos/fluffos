void got_addr(string host, string addr, int key) { }
void do_tests() {
    // With a configured resolver, resolve() queues a lookup and returns
    // an int handle; when DNS init failed (e.g. a CI sandbox with the
    // systemd stub resolver evdns rejects) it errors cleanly. Either
    // way it must NOT crash the driver.
    mixed err = catch(resolve("localhost", "got_addr"));
    ASSERT(err == 0 || stringp(err));
}
