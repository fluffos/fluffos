// load_object() (src/vm/internal/simulate.cc) builds a stack-local
// obname/real_name out of the (arbitrary-length, caller-controlled)
// object path plus a source extension. The destination buffers must be
// sized for the worst case (a ~399-char extension-less path plus the
// 4-char ".lpc" extension) -- undersizing them overflows the stack.
// This does not need the target file to exist: the overflow happens in
// the strcpy/strcat calls before any filesystem check.
void do_tests() {
  string long_name;
  int i;

  long_name = "/";
  for (i = 0; i < 399; i++) {
    long_name += "a";
  }

  // Just surviving this call (whether it errors cleanly because the
  // file doesn't exist, or returns 0) is the regression signal -- an
  // undersized buffer overflows the stack and ASan-aborts the whole
  // process before any of that logic runs.
  catch(load_object(long_name));
}
