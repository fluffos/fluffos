#ifdef __PACKAGE_PCRE__
void do_tests() {
    // The callback runs once per capture group of the match, receiving
    // (group_text, group_index), and its return replaces the group.
    ASSERT_EQ("A1 B2", pcre_replace_callback("a1 b2", "([a-z])[0-9] ([a-z])[0-9]",
                                             (: upper_case($1) :)));
    ASSERT_EQ("a0 b1", pcre_replace_callback("ax by", "a(x) b(y)",
                                             (: "" + $2 :)));
}
#endif
