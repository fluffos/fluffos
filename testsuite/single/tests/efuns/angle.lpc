private int near(float a, float b) { return (a > b ? a - b : b - a) < 1e-9; }
void do_tests() {
    // Angle between perpendicular unit vectors is pi/2.
    ASSERT(near(1.5707963267948966, angle(({ 1, 0 }), ({ 0, 1 }))));
    ASSERT(near(0.0, angle(({ 2, 0 }), ({ 5, 0 }))));

    // Regression: angle()'s internal dotprod() used to signal errors via
    // sentinel float values, so a legitimate dot product landing exactly
    // on -INT_MAX+1 (== -2147483646) was misreported as "invalid arg"
    // instead of computing the (here, opposite-direction: pi) angle.
    ASSERT(near(3.141592653589793, angle(({ -2147483646, 0 }), ({ 1, 0 }))));

    // Still errors cleanly on genuinely mismatched sizes.
    ASSERT(catch(angle(({ 1, 2 }), ({ 1 }))));
}
