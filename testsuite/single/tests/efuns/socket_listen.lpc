#ifdef __PACKAGE_SOCKETS__
#include <socket.h>
#include <socket_err.h>
void rcb(int fd) {}
void lcb(int fd) {}
void do_tests() {
  int fd = socket_create(STREAM, "rcb");
  socket_bind(fd, 0);
  ASSERT_EQ(EESUCCESS, socket_listen(fd, "lcb"));
  socket_close(fd);
  // Listening without a bind fails.
  fd = socket_create(STREAM, "rcb");
  ASSERT(socket_listen(fd, "lcb") < 0);
  socket_close(fd);
}
#endif
