int called = 0;
int fpcalled = 0;

void func() { called = 1; }

void do_tests() {
#ifndef __NO_ADD_ACTION__
    object tp;
    function f = (: fpcalled = 1 :);
    function g = (: fpcalled = 2 :);

    SAVETP;
    enable_commands();
    add_action( "func", "bar" );
    ASSERT(remove_action( "func", "bar" ));
    RESTORETP;
    command("bar");
    ASSERT(!called);

    // Issue #992: actions added as a function expression can be removed
    // by passing the same function pointer.
    SAVETP;
    enable_commands();
    add_action( f, "baz" );
    ASSERT(!remove_action( g, "baz" ));  // different function: no match
    ASSERT(remove_action( f, "baz" ));
    RESTORETP;
    command("baz");
    ASSERT(!fpcalled);
#endif
}
