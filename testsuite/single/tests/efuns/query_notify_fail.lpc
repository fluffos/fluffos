void do_tests() {
  // The notify_fail message lives on the INTERACTIVE command giver;
  // with no interactive (autotest) the query returns 0 and setting
  // one is a harmless no-op.
  ASSERT_EQ(0, query_notify_fail());
  ASSERT_EQ(0, catch(notify_fail("nope\n")));
  ASSERT_EQ(0, query_notify_fail());
}
