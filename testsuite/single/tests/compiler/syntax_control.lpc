// Control-flow syntax matrix: do/while, for with comma clauses and
// empty header, dangling else, switch over strings and open-ended
// ranges with fallthrough, catch and time_expression in both their
// expression and block forms.
void do_tests() {
    int i, n, s;
    string r;

    // do/while runs the body at least once, loops on the condition.
    n = 0;
    do { n++; } while (0);
    ASSERT_EQ(1, n);
    n = 0;
    i = 0;
    do { n += 10; i++; } while (i < 3);
    ASSERT_EQ(30, n);

    // for(;;) with break/continue; commas in init and increment.
    s = 0;
    for (i = 0, n = 10; ; i++, n--) {
        if (i == 3) break;
        if (i == 1) continue;
        s += n;
    }
    ASSERT_EQ(18, s);   // i==0 adds 10, i==1 skipped, i==2 adds 8

    // while with a short-circuit condition.
    i = 0;
    while (i < 4 && i != 3) i++;
    ASSERT_EQ(3, i);

    // Dangling else binds to the nearest if.
    r = "";
    if (1)
        if (0) r = "inner";
        else r = "else-of-inner";
    ASSERT_EQ("else-of-inner", r);

    // switch over strings.
    r = "";
    switch ("dog") {
        case "cat": r = "cat"; break;
        case "dog": r = "dog"; break;
        default: r = "other";
    }
    ASSERT_EQ("dog", r);

    // switch with open-ended case ranges (..N and N..).
    for (i = 0; i < 4; i++) {
        int got = -99;
        switch (({ -5, 3, 25, 7 })[i]) {
            case ..0:   got = 0; break;
            case 1..9:  got = 1; break;
            case 20..:  got = 2; break;
            default:    got = 3;
        }
        ASSERT_EQ(({ 0, 1, 2, 1 })[i], got);
    }

    // Fallthrough between cases.
    n = 0;
    switch (2) {
        case 1: n += 1;
        case 2: n += 2;
        case 3: n += 4; break;
        case 4: n += 8;
    }
    ASSERT_EQ(6, n);

    // catch: expression form and block form.
    ASSERT_EQ(0, catch(1 + 1));
    ASSERT(catch(error("boom\n")));
    i = 0;
    ASSERT_EQ(0, catch { i = 5; });
    ASSERT_EQ(5, i);
    ASSERT(catch { error("boom\n"); });

    // time_expression: expression and block forms measure elapsed time.
    ASSERT(time_expression (1 + 1) >= 0);
    ASSERT(time_expression { for (i = 0; i < 10; i++) ; } >= 0);

    // Empty statement is legal.
    ;
    ASSERT(1);
}
