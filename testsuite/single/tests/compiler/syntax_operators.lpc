// Operator syntax matrix: precedence pins (the merged same-precedence
// token families L_EQ_NE / L_SHIFT / L_ORDER / L_INC_DEC must keep C
// semantics), every compound assignment, coalescing, short-circuiting,
// increment/decrement lvalue forms, comma expressions, ranges, casts.
int gcount;
int bump() { gcount++; return gcount; }

void do_tests() {
    int a, b;
    int *arr;
    mapping m;

    // Precedence pins (C rules).
    ASSERT_EQ(14, 2 + 3 * 4);
    ASSERT_EQ(20, (2 + 3) * 4);
    ASSERT_EQ(8, 1 << 2 + 1);        // '+' binds tighter than '<<'
    ASSERT_EQ(7, 7 & 3 | 4 ^ 1);     // & over ^ over |
    ASSERT_EQ(1, 10 > 3 == 1);       // relational over equality
    ASSERT_EQ(6, 2 * 3 % 4 + 4);
    ASSERT_EQ(1, 1 << 3 >> 3);       // shifts left-associative

    // Unary operators.
    a = 5;
    ASSERT_EQ(-5, -a);
    ASSERT_EQ(0, !a);
    ASSERT_EQ(1, !!a);
    ASSERT_EQ(-6, ~a);

    // Ternary: right-associative, nests without parentheses.
    ASSERT_EQ(2, 0 ? 1 : 1 ? 2 : 3);
    ASSERT_EQ(1, 1 ? 1 : 0 ? 2 : 3);

    // Assignment is right-associative and yields the assigned value.
    a = b = 3;
    ASSERT_EQ(3, a);
    ASSERT_EQ(3, b);
    ASSERT_EQ(4, a = 4);

    // Every compound assignment operator.
    a = 10;
    a += 2;  ASSERT_EQ(12, a);
    a -= 4;  ASSERT_EQ(8, a);
    a *= 3;  ASSERT_EQ(24, a);
    a /= 6;  ASSERT_EQ(4, a);
    a %= 3;  ASSERT_EQ(1, a);
    a = 6;
    a &= 3;  ASSERT_EQ(2, a);
    a |= 5;  ASSERT_EQ(7, a);
    a ^= 1;  ASSERT_EQ(6, a);
    a <<= 2; ASSERT_EQ(24, a);
    a >>= 3; ASSERT_EQ(3, a);
    a = 0; a ||= 9; ASSERT_EQ(9, a);
    a ||= 5;        ASSERT_EQ(9, a);
    a &&= 4;        ASSERT_EQ(4, a);
    a = 0; a &&= 4; ASSERT_EQ(0, a);

    // Null coalescing: only UNDEFINED coalesces -- 0 is a real value.
    m = ([ "k" : 0 ]);
    ASSERT_EQ(0, m["k"] ?? 5);
    ASSERT_EQ(5, m["missing"] ?? 5);
    m["n"] ??= 7; ASSERT_EQ(7, m["n"]);
    m["k"] ??= 7; ASSERT_EQ(0, m["k"]);

    // Short-circuit evaluation skips the right operand.
    gcount = 0;
    ASSERT_EQ(0, 0 && bump());
    ASSERT_EQ(0, gcount);
    ASSERT_EQ(1, 1 || bump());
    ASSERT_EQ(0, gcount);

    // ++/-- pre and post, on locals, array elements, mapping values.
    a = 5;
    ASSERT_EQ(5, a++);
    ASSERT_EQ(6, a);
    ASSERT_EQ(7, ++a);
    ASSERT_EQ(7, a--);
    ASSERT_EQ(6, a);
    ASSERT_EQ(5, --a);
    arr = ({ 1, 2 });
    arr[0]++;
    ++arr[1];
    ASSERT_EQ(({ 2, 3 }), arr);
    m = ([ "x" : 1 ]);
    m["x"]++;
    ASSERT_EQ(2, m["x"]);

    // Comma expression evaluates left to right, yields the last value.
    gcount = 0;
    a = (bump(), bump(), 42);
    ASSERT_EQ(42, a);
    ASSERT_EQ(2, gcount);

    // Range and reverse-index forms on arrays and strings.
    arr = ({ 0, 1, 2, 3, 4 });
    ASSERT_EQ(({ 1, 2, 3 }), arr[1..3]);
    ASSERT_EQ(({ 2, 3, 4 }), arr[2..]);
    // (There is no open-LOW index range "[..n]" -- spell it "[0..n]".
    // Only switch case labels support the "..n" form.)
    ASSERT_EQ(4, arr[<1]);
    ASSERT_EQ(({ 3, 4 }), arr[<2..<1]);
    ASSERT_EQ(({ 1, 2, 3 }), arr[1..<2]);
    ASSERT_EQ("ell", "hello"[1..3]);

    // Casts are compile-time TYPE ASSERTIONS, not conversions (values
    // pass through unchanged) -- use to_int()/to_float() to convert.
    ASSERT_EQ(3, to_int(3.7));
    ASSERT_EQ(3.0, to_float(3));
    {
        mixed mx = 2.5;
        ASSERT(floatp((float)mx));   // cast syntax parses; value intact
        ASSERT_EQ(2.5, (float)mx);
    }
    ASSERT_EQ("3", "" + 3);
}
