void do_tests() {
  object tp;
  object saved = this_player();
  tp = clone_object("/single/void");
  set_this_player(tp);
  write("this_player() = " + (this_player() ? file_name(this_player()) : "0") + "\n");
  write("environment(tp) = " + (environment(tp) ? "yes" : "no") + "\n");
  set_this_player(saved);
  destruct(tp);
  ASSERT(1);
}
