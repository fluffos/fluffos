mixed *g_arr;
int calls;
int cmp(mixed a, mixed b) {
    calls++;
    if (calls == 5) {
        // shrink the array we're mid-sort on
        g_arr = g_arr[0..2];
    }
    return a - b;
}
void do_tests() {
    int i;
    g_arr = allocate(500);
    for (i = 0; i < 500; i++) g_arr[i] = 500 - i;
    sort_array(g_arr, "cmp", this_object());
}
