void do_tests() {
    string a, b;
    int n;
    catch(sscanf("", "%s", a));
    catch(sscanf("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "%d", n));
    string fmt = "";
    int i;
    for (i = 0; i < 500; i++) fmt += "%s ";
    catch(sscanf("x", fmt, a));
    catch(sscanf("%s%s%s%s", "%s%s", a, b));
}
