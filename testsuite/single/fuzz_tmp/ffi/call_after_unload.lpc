// PoC: ffi_call() caches a resolved dlsym() address in FfiFunc::addr at
// ffi_prepare() time and never re-validates that the owning library is
// still loaded. ffi_unload() dlclose()s the handle with no reference
// check against outstanding FfiFunc entries, so calling an
// already-prepared function after its library was unloaded calls into
// unmapped memory.
#ifdef __PACKAGE_FFI__
#include <ffi.h>
#endif
void do_tests() {
#ifdef __PACKAGE_FFI__
  int lib, f;
  lib = ffi_load("/tmp/claude-0/-home-user-fluffos/30de196a-75ac-5af7-8559-a2ea6eb3714a/scratchpad/vlib.so");
  if (lib <= 0) { ASSERT(1); return; }
  f = ffi_prepare(lib, "vlib_add", FFI_INT32, ({ FFI_INT32, FFI_INT32 }));
  ffi_unload(lib);
  // vlib.so may now be fully unmapped; addr is stale.
  ffi_call(f, ({ 1, 2 }));
#endif
  ASSERT(1);
}
