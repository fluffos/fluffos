// Helper for testsuite/single/tests/efuns/reload_object_self_destruct.lpc:
// a separate, never-reloaded object that lets the target fixture tell
// its first create() (at load time) apart from a later one (triggered
// by reload_object()), since reload_object() re-initializes the
// target's own variables before re-running create().
int count = 0;
int bump() { return ++count; }
